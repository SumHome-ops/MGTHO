{
  "version": 2,
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-cron-secret" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/sequence-runner",
      "schedule": "0 14 * * *"
    }
  ]
}
